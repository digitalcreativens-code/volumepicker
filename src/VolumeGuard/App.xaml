<Application x:Class="VolumeGuard.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
  <Application.Resources>
    <SolidColorBrush x:Key="BgBrush" Color="#FF1E1E1E"/>
    <SolidColorBrush x:Key="FgBrush" Color="#FFE8E8E8"/>
    <SolidColorBrush x:Key="MutedBrush" Color="#FF9A9A9A"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#FF3B82F6"/>
  </Application.Resources>
</Application>
