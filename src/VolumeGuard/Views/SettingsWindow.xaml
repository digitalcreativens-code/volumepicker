<Window x:Class="VolumeGuard.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Podešavanja"
        Height="520" Width="640"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Width="100" Margin="0,0,8,0" Content="Otkaži" IsCancel="True" Click="Cancel_Click"/>
      <Button Width="100" Content="Sačuvaj" IsDefault="True" Click="Save_Click"/>
    </StackPanel>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <TextBlock Foreground="{StaticResource FgBrush}" FontSize="16" Text="Raspored"/>
        <TextBlock Margin="0,6,0,12" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}"
                   Text="Format HH:mm. Noćni slot može prelaziti ponoć (npr. 22:00–06:30). Rupa 07:30–08:30 koristi prethodni limit (40%)."/>
        <DataGrid x:Name="GridSlots" AutoGenerateColumns="False" CanUserAddRows="True" CanUserDeleteRows="True"
                  HeadersVisibility="Column" Height="220" Margin="0,0,0,16"/>

        <TextBlock Foreground="{StaticResource FgBrush}" FontSize="16" Text="Ostalo"/>
        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
          <TextBlock VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Text="Interval provere (ms):" Width="180"/>
          <TextBox x:Name="TxtPoll" Width="120" Height="26"/>
        </StackPanel>
        <CheckBox x:Name="ChkProtection" Margin="0,12,0,0" Foreground="{StaticResource FgBrush}"
                  Content="Zaštita aktivna (ograničavanje volume-a)"/>
        <CheckBox x:Name="ChkStartup" Margin="0,8,0,0" Foreground="{StaticResource FgBrush}"
                  Content="Pokreni sa Windows-om (HKCU Run)"/>
        <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}"
                   Text="Napomena: isključivanje auto-starta i izmene rasporeda zahtevaju šifru (već ste je uneli otvaranjem ovog prozora)."/>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
