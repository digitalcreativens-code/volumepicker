<Window x:Class="VolumeGuard.Views.FirstRunPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VolumeGuard — prvi start"
        Height="300" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="16"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="8"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="16"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="8"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="24"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <TextBlock Grid.Row="0" TextWrapping="Wrap" Foreground="{StaticResource FgBrush}"
               Text="Postavite master šifru. Biće potrebna za izlazak, podešavanja i isključivanje auto-starta."/>
    <TextBlock Grid.Row="2" Foreground="{StaticResource MutedBrush}" Text="Šifra"/>
    <PasswordBox x:Name="Pwd1" Grid.Row="4" Height="28"/>
    <TextBlock Grid.Row="6" Foreground="{StaticResource MutedBrush}" Text="Ponovi šifru"/>
    <PasswordBox x:Name="Pwd2" Grid.Row="8" Height="28"/>
    <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Width="100" Margin="0,0,8,0" Content="Izađi" IsCancel="True" Click="Exit_Click"/>
      <Button Width="100" Content="Sačuvaj" IsDefault="True" Click="Save_Click"/>
    </StackPanel>
  </Grid>
</Window>
