<Window x:Class="VolumeGuard.Views.PasswordPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Potvrda šifre"
        Height="200" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="12"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="20"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <TextBlock Grid.Row="0" Foreground="{StaticResource FgBrush}" Text="Unesite master šifru:"/>
    <PasswordBox x:Name="PwdBox" Grid.Row="2" Height="28"/>
    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Width="90" Margin="0,0,8,0" Content="Otkaži" IsCancel="True" Click="Cancel_Click"/>
      <Button Width="90" Content="OK" IsDefault="True" Click="Ok_Click"/>
    </StackPanel>
  </Grid>
</Window>
