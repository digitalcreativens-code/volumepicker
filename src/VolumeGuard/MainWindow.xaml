<Window x:Class="VolumeGuard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VolumeGuard"
        Height="420" Width="520"
        MinHeight="360" MinWidth="480"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource FgBrush}"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="16"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock FontSize="20" Text="VolumeGuard"/>
      <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}" Text="Kontrola maksimalnog sistemskog volume-a po rasporedu."/>
    </StackPanel>

    <Border Grid.Row="2" Padding="16" CornerRadius="8" Background="#FF252525" BorderBrush="#FF333333" BorderThickness="1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="220"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="12"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="10"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="10"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="10"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="10"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="10"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Foreground="{StaticResource MutedBrush}" Text="Zaštita"/>
        <TextBlock Grid.Row="0" Grid.Column="1">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Text" Value="Isključeno"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding ProtectionEnabled}" Value="True">
                  <Setter Property="Text" Value="Uključeno"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>

        <TextBlock Grid.Row="2" Grid.Column="0" Foreground="{StaticResource MutedBrush}" Text="Dozvoljeni maksimum"/>
        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AllowedPercent, StringFormat={}{0:0}%}"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Foreground="{StaticResource MutedBrush}" Text="Trenutni sistemski volume"/>
        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CurrentPercent, StringFormat={}{0:0}%}"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Foreground="{StaticResource MutedBrush}" Text="Aktivni slot"/>
        <TextBlock Grid.Row="6" Grid.Column="1" TextWrapping="Wrap" Text="{Binding SlotDescription}"/>

        <TextBlock Grid.Row="8" Grid.Column="0" Foreground="{StaticResource MutedBrush}" Text="Watchdog"/>
        <TextBlock Grid.Row="8" Grid.Column="1">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Text" Value="Ne"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding WatchdogAlive}" Value="True">
                  <Setter Property="Text" Value="Da"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>

        <TextBlock Grid.Row="10" Grid.Column="0" Foreground="{StaticResource MutedBrush}" Text="Auto-start (HKCU Run)"/>
        <TextBlock Grid.Row="10" Grid.Column="1">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Text" Value="Ne"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding StartupEnabled}" Value="True">
                  <Setter Property="Text" Value="Da"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>

        <TextBlock Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}"
                   Text="Volume se proverava na svim aktivnim izlaznim audio uređajima (master)."/>
      </Grid>
    </Border>
  </Grid>
</Window>
